                *{{ i.name }}_in_sub.lock().unwrap() = Some(msg);
            },
        )?;
{% endfor %}{% for o in node.outputs %}        let {{ o.name }}_pub = node.create_publisher::<{{ o.rust_type }}>("{{ o.topic }}")?;
{% endfor %}        Ok(Arc::new(Self {
            node,
{% for i in node.inputs %}            {{ i.name }},
{% endfor %}{% for p in node.params %}            {{ p.name }}_param,
{% endfor %}{% for o in node.outputs %}            {{ o.name }}_pub,
