impl {{ node.struct_name }} {
    /// ノードを作成し、Subscriber / Publisher / パラメータを配線する
    pub fn new(executor: &rclrs::Executor) -> Result<Arc<Self>, rclrs::RclrsError> {
        let node = executor.create_node("{{ node.node_name }}")?;
{% for p in node.params %}        let {{ p.name }}_param = node
            .declare_parameter("{{ p.name }}")
            .default({{ p.rust_default }})
            .mandatory()?;
{% endfor %}{% for i in node.inputs %}        let {{ i.name }}: Arc<Mutex<Option<{{ i.rust_type }}>>> = Arc::new(Mutex::new(None));
        let {{ i.name }}_in_sub = Arc::clone(&{{ i.name }});
        let {{ i.name }}_sub = node.create_subscription(
